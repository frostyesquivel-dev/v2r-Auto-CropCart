// --- PIN DEFINITIONS ---
// DC Motors
#define M1_PWM 6
#define M1_DIR 23
#define M2_PWM 5
#define M2_DIR 22

// Stepper Pins
#define PUL_PIN 3
#define DIR_PIN 4

// --- GLOBAL VARIABLES ---
int targetSpeed = 80;

// --- HELPER FUNCTIONS ---
// Must be defined before loop() so the compiler knows they exist

void stopMotors() {
  analogWrite(M1_PWM, 0);
  analogWrite(M2_PWM, 0);
}

void overdriveMove(int outputRotations, bool forward) {
  digitalWrite(DIR_PIN, forward ? LOW : HIGH);
  delay(100); 

  long totalSteps = (long)outputRotations * 4000; 
  int startDelay = 800;  
  int cruiseDelay = 180; 
  long rampSteps = 1000; 

  for (long i = 0; i < totalSteps; i++) {
    int currentDelay;
    if (i < rampSteps) currentDelay = map(i, 0, rampSteps, startDelay, cruiseDelay);
    else if (i > (totalSteps - rampSteps)) currentDelay = map(i, totalSteps - rampSteps, totalSteps, cruiseDelay, startDelay);
    else currentDelay = cruiseDelay;

    digitalWrite(PUL_PIN, LOW);
    delayMicroseconds(currentDelay);
    digitalWrite(PUL_PIN, HIGH);
    delayMicroseconds(currentDelay);
  }
}

// --- MAIN SETUP ---
void setup() {
  Serial.begin(9600);
  pinMode(M1_PWM, OUTPUT);
  pinMode(M1_DIR, OUTPUT);
  pinMode(M2_PWM, OUTPUT);
  pinMode(M2_DIR, OUTPUT);
  
  pinMode(PUL_PIN, OUTPUT);
  pinMode(DIR_PIN, OUTPUT);
  
  digitalWrite(PUL_PIN, HIGH);
  digitalWrite(DIR_PIN, HIGH);
  
  stopMotors();
  Serial.println("System Ready - Waiting for Commands");
}

// --- MAIN LOOP ---
void loop() {
  if (Serial.available() > 0) {
    char command = Serial.read(); 

    // Command 'F': Trigger the Wheel Ramp Sequence
    if (command == 'F' || command == '1') {
      digitalWrite(M1_DIR, LOW); 
      digitalWrite(M2_DIR, LOW); 

      // Acceleration Ramp
      for (int s = 0; s <= targetSpeed; s++) {
        analogWrite(M1_PWM, s);
        analogWrite(M2_PWM, s);
        delay(40);
      }
      
      delay(1000); // Cruise

      // Deceleration Ramp
      for (int s = targetSpeed; s >= 0; s--) {
        analogWrite(M1_PWM, s);
        analogWrite(M2_PWM, s);
        delay(40);
      }

      stopMotors();
      Serial.println("WHEELS_DONE");
    }

    // Command 'S': Trigger the Stepper Sequence
    else if (command == 'S') {
      overdriveMove(2, true);
      delay(800);
      overdriveMove(4, false);
      delay(800);
      overdriveMove(2, true);
      Serial.println("STEPPER_DONE");
    }
  }
}
