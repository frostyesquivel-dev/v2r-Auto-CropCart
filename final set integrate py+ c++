import cv2
import numpy as np
import serial
import time
from ultralytics import YOLO

# --- CONFIGURATION ---
SERIAL_PORT = '/dev/ttyACM0'
MODEL_PATH = '/home/jonahesq/ultralytics/runs/segment/train5/weights/best_openvino_model/'
CAMERA_INDICES = [0, 2, 4] 
SCAN_DURATION = 20 
HEALTHY_COLOR = (255, 191, 0) # Light Blue
UNHEALTHY_COLOR = (0, 0, 255) # Red

model = YOLO(MODEL_PATH)

def get_cameras():
    """Initializes cameras with a staggered delay to ensure all 3 open."""
    caps = []
    for idx in CAMERA_INDICES:
        print(f"Attempting to open Camera {idx}...")
        cap = cv2.VideoCapture(idx, cv2.CAP_V4L2)
        # Give the USB bus a moment to breathe between cameras
        time.sleep(0.5) 
        
        cap.set(cv2.CAP_PROP_FOURCC, cv2.VideoWriter_fourcc(*'MJPG'))
        cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
        cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)
        
        if cap.isOpened():
            # Clear the buffer to get a fresh frame
            for _ in range(5): cap.read() 
            caps.append(cap)
            print(f"Camera {idx} SUCCESS.")
        else:
            print(f"Camera {idx} FAILED.")
    return caps

try:
    ser = serial.Serial(SERIAL_PORT, 9600, timeout=1)
    time.sleep(2)

    # 1. WHEELS (Now matches the shorter Arduino move)
    print("\n[1/4] Triggering Short Wheel Pulse...")
    if ser: ser.write(b'F')
    # Wait for the new 2.5s physical move to finish
    time.sleep(3) 

    # 2. YOLO SCAN (20 Seconds)
    print(f"[2/4] Starting 20s Scan with 3 Cameras...")
    active_caps = get_cameras()
    
    # If a camera is missing, we still want to show 3 boxes (one black)
    scan_start = time.time()
    while time.time() - scan_start < SCAN_DURATION:
        frames = []
        for i in range(3):
            if i < len(active_caps):
                ret, frame = active_caps[i].read()
                if ret:
                    results = model.predict(frame, conf=0.15, imgsz=320, verbose=False)
                    annotated = frame.copy()
                    for r in results:
                        for box in r.boxes:
                            cls = int(box.cls[0])
                            color = HEALTHY_COLOR if cls == 0 else UNHEALTHY_COLOR
                            b = box.xyxy[0].cpu().numpy().astype(int)
                            cv2.rectangle(annotated, (b[0], b[1]), (b[2], b[3]), color, 2)
                            cv2.putText(annotated, model.names[cls], (b[0], b[1]-10),
                                        cv2.FONT_HERSHEY_SIMPLEX, 0.5, color, 1)
                    frames.append(cv2.resize(annotated, (640, 480)))
                    continue
            
            # If camera failed or index is out of range, show black box
            frames.append(np.zeros((480, 640, 3), dtype=np.uint8))

        combined = np.hstack(frames)
        display_frame = cv2.resize(combined, (0, 0), fx=0.5, fy=0.5)
        
        elapsed = int(time.time() - scan_start)
        cv2.putText(display_frame, f"SCANNING: {elapsed}/{SCAN_DURATION}s", (20, 40), 
                    cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 255), 2)
        cv2.imshow("Crop Cart Dashboard", display_frame)
        
        if cv2.waitKey(1) & 0xFF == ord('q'): break

    # 3. CLEANUP CAMS
    for cap in active_caps: cap.release()
    cv2.destroyAllWindows()

    # 4. STEPPER
    print("[4/4] Engaging Stepper...")
    if ser: ser.write(b'S')
    time.sleep(8)

finally:
    if 'ser' in locals(): ser.close()
    print("Cycle Complete.")





